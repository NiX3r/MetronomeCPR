<?xml version="1.0" encoding="UTF-8"?>
<!--
    Connect IQ app settings. These appear as the app's "settings" gear in the
    Connect IQ mobile app / Garmin Connect, and (once changed) sync to the watch.
    The same value can also be edited on-device via the in-app Settings menu.
-->
<settings>
    <setting propertyKey="@Properties.feedbackMode" title="@Strings.SettingFeedback">
        <settingConfig type="list">
            <listEntry value="0">@Strings.FeedbackBeep</listEntry>
            <listEntry value="1">@Strings.FeedbackVibrate</listEntry>
            <listEntry value="2">@Strings.FeedbackBoth</listEntry>
        </settingConfig>
    </setting>
</settings>
