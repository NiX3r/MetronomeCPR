<?xml version="1.0" encoding="UTF-8"?>
<!-- Default values for the app settings above. Each feedback channel is independent. -->
<properties>
    <property id="beepOn"    type="boolean">true</property>   <!-- speaker tone on each beat -->
    <property id="vibrateOn" type="boolean">true</property>   <!-- vibration on each beat -->
    <property id="flashOn"   type="boolean">false</property>  <!-- blink the flashlight/backlight on each beat -->
</properties>
