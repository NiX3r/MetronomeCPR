<?xml version="1.0" encoding="UTF-8"?>
<!--
    Connect IQ application manifest.
    App id is a generated UUID and must stay stable across releases.
    Add more <iq:product> entries as device coverage expands (goal: all watches).
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application id="cd68498bc3c64e9d92fddcd442b25fb8"
                    type="watch-app"
                    name="@Strings.AppName"
                    entry="MetronomeCprApp"
                    launcherIcon="@Drawables.LauncherIcon"
                    minApiLevel="3.1.0">
        <iq:products>
            <!-- Reference device: Garmin Instinct 2X Solar -->
            <iq:product id="instinct2x"/>
        </iq:products>
        <!-- No special permissions required: Attention (tone/vibe) needs none -->
        <iq:permissions/>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
